{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "es6",
    "esModuleInterop": true,
    "target": "es2016",
    "lib": [
      "es7",
      "dom"
    ],
    "moduleResolution": "node",
    "outDir": "dist",
    "sourceMap": true,
    "strict": false,
    "removeComments": true,
    "paths":{
      "@analytics/*": ["src/analytics/*"],
      "@assessment/*": ["src/assessment/*"],
      "@components/*": ["src/components/*"],
      "@configs/*": ["src/config/*"],
      "@survey/*": ["src/survey/*"],
      "@ui/*": ["src/ui/*"],
      "@utils/*": ["src/utils/*"],
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ],
}