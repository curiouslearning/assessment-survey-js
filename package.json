{
  "name": "@curiouslearning/assessment-survey",
  "version": "0.0.1",
  "description": "typescript implementation of the assessment / survey",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public",
    "data"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register-web-component.d.ts",
      "import": "./dist/register-web-component.js",
      "default": "./dist/register-web-component.js"
    }
  },
  "scripts": {
    "start": "npm run dev",
    "wb:inject": "workbox injectManifest",
    "webpack": "npm run build && live-server build",
    "build": "npm run build:standalone && npm run wb:inject",
    "build:standalone": "cross-env NODE_ENV=production webpack -c webpack.config.js --mode=production",
    "build:package": "tsc -p tsconfig.package.json && tsc-alias -p tsconfig.package.json",
    "build:all": "npm run build:standalone && npm run build:package",
    "test": "jest",
    "dev": "cross-env NODE_ENV=development webpack serve -c webpack.config.js --mode=development",
    "prepublishOnly": "npm run build:package",
    "tsc-build": "tsc && tsc-bundle tsconfig.json --exportAs Bundle --entryPoint App --outFile bundle.js",
    "tsc-run": "tsc && tsc-bundle tsconfig.json --exportAs Bundle --entryPoint App --outFile bundle.js && live-server",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/curiouslearning/assessment-survey-js.git"
  },
  "author": "curious learning",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/curiouslearning/assessment-survey-js/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.26.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "live-server": "^1.2.2",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.4.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "~4.8.3",
    "typescript-bundle": "^1.0.18",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.15.1",
    "workbox-cli": "^7.3.0"
  },
  "dependencies": {
    "@curiouslearning/analytics": "^1.3.1",
    "@curiouslearning/assessment-survey": "file:",
    "@curiouslearning/core": "^1.10.0",
    "firebase": "^9.12.1",
    "jest-environment-jsdom": "^29.7.0",
    "workbox-core": "^7.0.0",
    "workbox-window": "^7.0.0",
    "xhr2": "^0.2.1"
  }
}
