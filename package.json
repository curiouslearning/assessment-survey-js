{
  "name": "assessment-survey-js",
  "version": "0.0.1",
  "description": "typescript implementation of the assessment / survey",
  "main": "bundle.js",
  "scripts": {
    "start": "npx concurrently \"node ./node_modules/webpack/bin/webpack.js --config webpack.config.js --watch\" \"npx http-server dist -p 8080 -c-1\"",
    "webpack": "npx webpack && npx live-server",
    "dev": "npx webpack serve -c webpack.config.js --port 8080 && npm run wb:inject",
    "build": "cross-env NODE_ENV=production npx webpack -c webpack.config.js --mode=production && npm run wb:inject",
    "test": "jest",
    "tsc-build": "tsc && tsc-bundle tsconfig.json --exportAs Bundle --entryPoint App --outFile bundle.js",
    "tsc-run": "tsc && tsc-bundle tsconfig.json --exportAs Bundle --entryPoint App --outFile bundle.js && live-server",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/curiouslearning/assessment-survey-js.git"
  },
  "author": "curious learning",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/curiouslearning/assessment-survey-js/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.26.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "live-server": "^1.2.2",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.4.1",
    "ts-node": "^10.9.2",
    "typescript": "~4.8.3",
    "typescript-bundle": "^1.0.18",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "@curiouslearning/analytics": "^1.3.0",
    "firebase": "^9.12.1",
    "jest-environment-jsdom": "^29.7.0",
    "workbox-cli": "^7.0.0",
    "workbox-core": "^7.0.0",
    "workbox-window": "^7.0.0",
    "xhr2": "^0.2.1"
  }
}
